[flake8]
max-line-length = 88
max-complexity = 10
select = E,W,F,C
ignore = 
    # Line too long (handled by black)
    E501,
    # Line break before binary operator (conflicts with black)
    W503,
    # Line break after binary operator (conflicts with black)
    W504,
    # Whitespace before ':' (conflicts with black)
    E203,
    # Multiple imports on one line
    E401,
    # Module level import not at top of file
    E402
exclude = 
    .git,
    __pycache__,
    .pytest_cache,
    .mypy_cache,
    .tox,
    .venv,
    venv,
    hydrology_env,
    build,
    dist,
    *.egg-info,
    .eggs,
    docs/_build,
    examples/temp_gis,
    temp_gis
per-file-ignores =
    # Allow unused imports in __init__.py files
    __init__.py:F401,F403
    # Allow star imports in test files
    tests/*.py:F401,F403
    # Allow long lines in configuration files
    setup.py:E501
count = True
statistics = True
show-source = True
bench-mark = True